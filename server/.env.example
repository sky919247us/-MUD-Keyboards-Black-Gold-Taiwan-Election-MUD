# 伺服器設定
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Tick 間隔（秒），測試用 30，正式為 600
TICK_INTERVAL=30

# AI 結算引擎：mock / openai / gemini
# ===== AI 結算引擎 (請選擇一個並註解另一個) =====
AI_PROVIDER="gemini"
GEMINI_API_KEY="你的_Gemini_API_Key"

# AI_PROVIDER="openai"
# OPENAI_API_KEY="你的_OPENAI_API_KEY"

# 中央氣象署開放資料授權金鑰
CWA_API_KEY=

# WebSocket 簽章密鑰（生產環境必須設定，建議 32 字元以上隨機字串）
WS_SECRET_KEY=

# 資料庫（Phase 2）
DATABASE_URL=memory://
